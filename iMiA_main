        % Value changed function: DropDown_5
        function DropDown_5ValueChanged(app, event)
            value = app.DropDown_5.Value;
            switch value
                case 'Laplace'
                    x = laplace_filter(app.imaginea);
                case 'Sobel Gradient'
                    x = sobel_gradient(app.imaginea);
                case 'Sharpen'
                    x = sharpen_image(app.imaginea);
                case 'Smooth Sobel Gradient'
                    x= smooth_sobel_gradient(app.imaginea);
                case 'Unfiltered'
                    x = app.imageToDisplay;
            end
            app.Image6.ImageSource = x;
            app.leftImage = x;
        end

