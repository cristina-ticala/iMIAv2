        % Button pushed function: LoadimageButton
        function LoadimageButtonPushed(app, event)
            filterspec = {'*.jpg;*.tif;*.png;*.gif','All Image Files'};
            [file,path] = uigetfile(filterspec);
            try
                imagefile = [path file];
                im = imread(imagefile);
                if size(im,3) == 1
                    im = cat(3,im,im,im);
                end
                im = impadding(im);
                im = imresize(im,[512 512]);
                app.imageToDisplay = im;
                app.Image.ImageSource = im;
                app.imaginea = double(im2gray(im))/255;
                app.imaginea = app.imaginea(:,:,1);
                app.roiImage = app.imaginea;
                app.GenerateedgeButton.Enable = true;
                app.FiltersButton.Enable = true;
                app.RegionofinterestButton.Enable = true;
                app.ZoomimageandedgesButton.Enable = true;
                app.SegmentationButton.Enable = true;
                app.ClusteringButton.Enable = true;
                app.FuzzyprocessingButton.Enable = true;
                %app.Image3.ImageSource = im;
                %app.Image4.ImageSource = im;
                %app.Image_ROI1.ImageSource = im;
                [~,~,app.cannyEdge] = predefined_edges1(app.imaginea,'Canny');
                catch ME
                % If problem reading image, display error message
                uialert(app.UIFigure,ME.message,"Image Error");
            return;
            end
        end

