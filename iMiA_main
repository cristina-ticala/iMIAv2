            app.leftFlattenedImage = app.leftFlattenedImage(:,:,1);
            app.rightFlattenedImage = double(im2gray(app.rightImage))/255;
            app.rightFlattenedImage = app.rightFlattenedImage(:,:,1);

            [p1,~, app.leftEdge] = predefined_edges1(app.leftFlattenedImage,value);
            app.Image8.ImageSource = app.leftEdge;
   
            [p2,~,app.rightEdge] = predefined_edges1(app.rightFlattenedImage,value);
            app.Image9.ImageSource = app.rightEdge;
