        % Button pushed function: SaveallimagesButton
        function SaveallimagesButtonPushed(app, event)
                folderPath = uigetdir(pwd, 'Select Folder to Save Images');
                
            if folderPath == 0
                disp('No folder selected. Operation cancelled.');
            end
            %imageCellArray = [app.enhancedImage, app.m1,app.m2, app.m3, app.m4];
            % Loop through images and save them
            %for i = 1:size(imageCellArray)
              %  imageToSave = imageCellArray(i);
                fileName = fullfile(folderPath, sprintf('%s.png', 'enhanced'));
                imwrite(app.enhancedImage, fileName);
                fprintf('Saved image %d to: %s\n', 1, fileName);
                fileName = fullfile(folderPath, sprintf('%s.png', 'cluster1'));
                imwrite(app.m1, fileName);
                fprintf('Saved image %d to: %s\n', 1, fileName);
                fileName = fullfile(folderPath, sprintf('%s.png', 'cluster2'));
                imwrite(app.m2, fileName);
                fprintf('Saved image %d to: %s\n', 1, fileName);
                fileName = fullfile(folderPath, sprintf('%s.png', 'cluster3'));
                imwrite(app.m3, fileName);
                fprintf('Saved image %d to: %s\n', 1, fileName);
                fileName = fullfile(folderPath, sprintf('%s.png', 'cluster4'));
                imwrite(app.m4, fileName);
                fprintf('Saved image %d to: %s\n', 1, fileName);

            disp('All images saved successfully.');
        end

